<% if (errors && errors.length) { %>
<div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= errors[0] %></div>
<% } %>

<div class="row justify-content-center">
<div class="col-xl-9">
<div class="card-sicis">
  <div class="card-sicis-header"><i class="bi bi-arrow-left-right me-2"></i>Datos del Movimiento</div>
  <div class="card-sicis-body">
    <form method="POST" action="/movimientos" id="movForm">
      <div class="row g-3">

        <!-- Categoria y tipo de movimiento -->
        <div class="col-md-6">
          <label class="form-label required">Categoria</label>
          <select name="categoria" class="form-select" required id="categoriaSelect">
            <option value="">Seleccionar...</option>
            <% for (const c of (categorias || [])) { %>
            <option value="<%= c.value %>"><%= c.label %></option>
            <% } %>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label required">Tipo de Movimiento</label>
          <select name="tipo_movimiento" class="form-select" required id="tipoMovimientoSelect">
            <option value="">Seleccionar...</option>
            <% for (const t of (tiposMovimiento || [])) { %>
            <option value="<%= t.value %>" data-requiere-uso="<%= t.requiere_tipo_uso ? 'true' : 'false' %>"><%= t.label || tipoMovimientoLabel(t.value) %></option>
            <% } %>
          </select>
        </div>

        <!-- Insecticida y Lote -->
        <div class="col-md-6">
          <label class="form-label required">Insecticida</label>
          <select name="insecticida_id_filtro" class="form-select" id="insectSelect">
            <option value="">Seleccionar insecticida...</option>
            <% for (const i of insecticidas) { %>
            <% const usos = Array.isArray(i.tipo_usos) && i.tipo_usos.length ? i.tipo_usos : [i.tipo_uso]; %>
            <option value="<%= i.id %>" data-usos="<%= usos.join(',') %>"><%= i.nombre %> (<%= usos.join(', ') %>)</option>
            <% } %>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label required">Lote</label>
          <select name="lote_id" class="form-select" id="loteSelect" required>
            <option value="">Seleccione primero un insecticida...</option>
          </select>
          <div id="loteInfo" class="form-text"></div>
        </div>

        <!-- Deposito Origen -->
        <div class="col-md-6" id="origenWrap">
          <label class="form-label" id="origenLabel">Deposito Origen</label>
          <select name="deposito_origen_id" class="form-select" id="origenSelect">
            <option value="">Seleccionar...</option>
            <% for (const d of depositos) { %>
            <option value="<%= d.id %>" data-nivel="<%= d.nivel %>"><%= d.nombre %> (Nivel <%= d.nivel %>)</option>
            <% } %>
          </select>
          <div id="stockDisponible" class="form-text text-success fw-bold"></div>
        </div>

        <!-- Deposito Destino -->
        <div class="col-md-6" id="destinoWrap">
          <label class="form-label" id="destinoLabel">Deposito Destino</label>
          <select name="deposito_destino_id" class="form-select" id="destinoSelect">
            <option value="">Seleccionar...</option>
            <% for (const d of depositos) { %>
            <option value="<%= d.id %>" data-nivel="<%= d.nivel %>"><%= d.nombre %> (Nivel <%= d.nivel %>)</option>
            <% } %>
          </select>
        </div>

        <!-- Cantidad y fecha -->
        <div class="col-md-4">
          <label class="form-label required">Cantidad</label>
          <div class="input-group">
            <input type="number" name="cantidad" class="form-control" required min="0.001" step="0.001" placeholder="0.000">
            <span class="input-group-text" id="unidadLabel">-</span>
          </div>
        </div>
        <div class="col-md-4">
          <label class="form-label required">Fecha del Movimiento</label>
          <input type="date" name="fecha_movimiento" class="form-control" required value="<%= new Date().toISOString().split('T')[0] %>">
        </div>
        <div class="col-md-4">
          <label class="form-label">Descripcion</label>
          <input type="text" name="descripcion" class="form-control" placeholder="Ej: Operativo zona norte">
        </div>
        <div class="col-12">
          <label class="form-label">Observaciones</label>
          <textarea name="observaciones" class="form-control" rows="2" placeholder="Observaciones adicionales..."></textarea>
        </div>
      </div>

      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Registrar Movimiento</button>
        <a href="/movimientos" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
</div>
</div>

<script>
// Datos lotes para filtrado
window.movimientoLotesData = <%- safeJson(lotes.map(l => ({ id: l.id, insecticida_id: l.insecticida_id, codigo_lote: l.codigo_lote, fecha_vencimiento: l.fecha_vencimiento, unidad_medida: l.unidad_medida }))) %>;
window.movimientoUsuarioRol = <%- safeJson(rolUsuario || '') %>;

function filtrarInsecticidasPorTipo() {
  const tipoSelect = document.getElementById('tipoMovimientoSelect');
  const tipo = tipoSelect.value;
  const requiereUso = tipoSelect.selectedOptions[0]?.dataset.requiereUso === 'true';
  const insectSelect = document.getElementById('insectSelect');
  Array.from(insectSelect.options).forEach(opt => {
    if (!opt.value) return;
    const usos = (opt.dataset.usos || '').split(',');
    opt.hidden = Boolean(requiereUso && tipo && !usos.includes(tipo));
  });
  if (insectSelect.selectedOptions[0]?.hidden) {
    insectSelect.value = '';
    filtrarLotes();
  }
}

function filtrarLotes() {
  const insId = document.getElementById('insectSelect').value;
  const sel = document.getElementById('loteSelect');
  const loteInfo = document.getElementById('loteInfo');
  const unidadLabel = document.getElementById('unidadLabel');
  sel.innerHTML = '<option value="">Seleccionar lote...</option>';
  document.getElementById('stockDisponible').textContent = '';
  if (loteInfo) loteInfo.textContent = '';
  if (unidadLabel) unidadLabel.textContent = '-';

  if (!insId) {
    sel.innerHTML = '<option value="">Seleccione primero un insecticida...</option>';
    return;
  }

  const lotesData = window.movimientoLotesData || [];
  const filtrados = lotesData.filter(l => l.insecticida_id == insId);
  if (!filtrados.length) {
    sel.innerHTML = '<option value="">Sin lotes vigentes para este insecticida</option>';
    return;
  }

  filtrados.forEach(l => {
    const opt = document.createElement('option');
    opt.value = l.id;
    opt.dataset.vence = l.fecha_vencimiento;
    opt.dataset.unidad = l.unidad_medida;
    opt.textContent = `${l.codigo_lote} - Vence: ${new Date(l.fecha_vencimiento).toLocaleDateString('es-PY')}`;
    sel.appendChild(opt);
  });
}

function onLoteChange() {
  const sel = document.getElementById('loteSelect');
  const opt = sel.options[sel.selectedIndex];
  if (opt && opt.value) {
    const vence = opt.dataset.vence;
    const unidad = opt.dataset.unidad || '';
    document.getElementById('unidadLabel').textContent = unidad;
    const dias = Math.floor((new Date(vence) - new Date()) / 86400000);
    document.getElementById('loteInfo').textContent = `Vencimiento: ${new Date(vence).toLocaleDateString('es-PY')} (${dias} dias)`;
    document.getElementById('loteInfo').className = `form-text ${dias < 30 ? 'text-danger' : dias < 90 ? 'text-warning' : 'text-success'}`;
  }
  cargarStockDisponible();
}

async function cargarStockDisponible() {
  const depId = document.getElementById('origenSelect').value;
  const loteId = document.getElementById('loteSelect').value;
  const div = document.getElementById('stockDisponible');
  if (!depId || !loteId) { div.textContent = ''; return; }

  const r = await fetch(`/api/stock/${depId}?insecticida_id=${document.getElementById('insectSelect').value || 0}`);
  const data = await r.json();
  const lote = data.find(x => x.lote_id == loteId);
  div.textContent = lote ? `Stock disponible: ${parseFloat(lote.cantidad).toFixed(3)} ${lote.unidad_medida}` : 'Sin stock para este lote en el deposito seleccionado';
  div.className = `form-text fw-bold ${lote ? 'text-success' : 'text-danger'}`;
}

function onCategoriaChange() {
  const cat = document.getElementById('categoriaSelect').value;
  const ow = document.getElementById('origenWrap');
  const dw = document.getElementById('destinoWrap');
  const os = document.getElementById('origenSelect');
  const ds = document.getElementById('destinoSelect');
  const limitarDestinoNivel1 = window.movimientoUsuarioRol === 'encargado_principal' && cat === 'entrada';

  Array.from(ds.options).forEach(opt => {
    if (!opt.value) return;
    opt.hidden = limitarDestinoNivel1 && opt.dataset.nivel !== '1';
  });
  if (limitarDestinoNivel1 && ds.selectedOptions[0]?.hidden) {
    ds.value = '';
  }

  if (cat === 'entrada') {
    ow.style.display = 'none'; os.required = false;
    dw.style.display = ''; ds.required = true;
  } else if (cat === 'salida') {
    ow.style.display = ''; os.required = true;
    dw.style.display = 'none'; ds.required = false;
  } else if (cat === 'transferencia') {
    ow.style.display = ''; os.required = true;
    dw.style.display = ''; ds.required = true;
  } else if (cat === 'ajuste') {
    ow.style.display = 'none'; os.required = false; os.value = '';
    dw.style.display = ''; ds.required = true;
  } else {
    ow.style.display = ''; os.required = false;
    dw.style.display = ''; ds.required = false;
  }

  if (window.sicisUpdateComboSelect) window.sicisUpdateComboSelect(ds);
}

onCategoriaChange();
filtrarInsecticidasPorTipo();
filtrarLotes();
</script>
