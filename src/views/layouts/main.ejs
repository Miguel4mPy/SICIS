<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= csrfToken || '' %>">
  <title><%= title %> - SICIS</title>
  <link rel="icon" href="/images/favicon.ico">
  <link rel="apple-touch-icon" href="/images/favicon_io/apple-touch-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600;700&family=Barlow+Condensed:wght@500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/sicis.css" rel="stylesheet">
</head>
<body class="app-body">

<nav class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <div class="sidebar-logo">
      <div class="sl-icon sl-logo-mark">
        <img src="/images/logo-senepa.png" alt="SENEPA" class="sidebar-logo-img">
      </div>
      <div class="sl-text">
        <span class="sl-name">SICIS</span>
        <span class="sl-sub">Sistema Informático de Control de Insecticida del SENEPA</span>
        <span class="sidebar-version">Version 1.0.0</span>
      </div>
    </div>
    <button class="sidebar-close d-lg-none" id="sidebarClose"><i class="bi bi-x-lg"></i></button>
  </div>

  <% if (user) { %>
  <div class="sidebar-user">
    <div class="su-avatar"><%= user.nombre.charAt(0) %><%= user.apellido.charAt(0) %></div>
    <div class="su-info">
      <div class="su-name"><%= user.nombre %> <%= user.apellido %></div>
      <div class="su-role badge-rol-<%= user.rol %>"><i class="bi bi-person-fill-gear me-1"></i><%= user.rol.toUpperCase() %></div>
    </div>
  </div>
  <% } %>

  <div class="sidebar-nav">
    <a href="/dashboard" class="nav-item <%= currentPath === '/dashboard' ? 'active' : '' %>">
      <i class="bi bi-speedometer2"></i><span>Dashboard</span>
    </a>

    <details class="nav-group" <%= currentPath.startsWith('/movimientos') ? 'open' : '' %>>
      <summary class="nav-section-toggle">
        <span><i class="bi bi-journal-plus"></i>Registros</span>
        <i class="bi bi-chevron-down nav-group-chevron"></i>
      </summary>
      <div class="nav-group-items">
        <a href="/movimientos" class="nav-item <%= currentPath.startsWith('/movimientos') ? 'active' : '' %>">
          <i class="bi bi-arrow-left-right"></i><span>Movimientos</span>
        </a>
        <a href="/movimientos/confirmaciones" class="nav-item <%= currentPath.startsWith('/movimientos/confirmaciones') ? 'active' : '' %>">
          <i class="bi bi-check2-square"></i><span>Confirmacion de Movimiento</span>
        </a>
      </div>
    </details>

    <details class="nav-group" <%= currentPath.startsWith('/reportes') ? 'open' : '' %>>
      <summary class="nav-section-toggle">
        <span><i class="bi bi-file-earmark-bar-graph"></i>Reportes</span>
        <i class="bi bi-chevron-down nav-group-chevron"></i>
      </summary>
      <div class="nav-group-items">
        <a href="/reportes/movimientos" class="nav-item <%= currentPath === '/reportes/movimientos' ? 'active' : '' %>">
          <i class="bi bi-journal-text"></i><span>Reporte de Movimientos</span>
        </a>
        <a href="/reportes/stock" class="nav-item <%= currentPath === '/reportes/stock' ? 'active' : '' %>">
          <i class="bi bi-clipboard-data"></i><span>Reporte de Stock</span>
        </a>
        <a href="/reportes/stock-general" class="nav-item <%= currentPath === '/reportes/stock-general' ? 'active' : '' %>">
          <i class="bi bi-grid-3x3-gap"></i><span>Reporte de Stock General</span>
        </a>
        <% if (userRol && (userRol === 'admin' || userRol === 'gerente')) { %>
        <a href="/reportes/grafico" class="nav-item <%= currentPath === '/reportes/grafico' ? 'active' : '' %>">
          <i class="bi bi-bar-chart-fill"></i><span>Graficos</span>
        </a>
        <% } %>
      </div>
    </details>

    <% if (userRol === 'admin' || userRol === 'encargado_principal') { %>
    <details class="nav-group" <%= (currentPath.startsWith('/usuarios') || currentPath.startsWith('/depositos') || currentPath.startsWith('/insecticidas') || currentPath.startsWith('/lotes') || currentPath.startsWith('/tipos-uso') || currentPath.startsWith('/tipos-movimiento') || currentPath.startsWith('/unidades-medida') || currentPath.startsWith('/presentaciones') || currentPath.startsWith('/logs')) ? 'open' : '' %>>
      <summary class="nav-section-toggle">
        <span><i class="bi bi-gear-fill"></i>Administracion</span>
        <i class="bi bi-chevron-down nav-group-chevron"></i>
      </summary>
      <div class="nav-group-items">
        <% if (userRol === 'admin') { %>
        <div class="nav-subsection-label">Herramientas del Sistema</div>
        <a href="/usuarios" class="nav-item <%= currentPath.startsWith('/usuarios') ? 'active' : '' %>">
          <i class="bi bi-people-fill"></i><span>Usuarios</span>
        </a>
        <a href="/logs" class="nav-item <%= currentPath.startsWith('/logs') ? 'active' : '' %>">
          <i class="bi bi-activity"></i><span>Logs</span>
        </a>
        <% } %>
        <div class="nav-subsection-label">Gestion de Insecticidas</div>
        <% if (userRol === 'admin') { %>
        <a href="/depositos" class="nav-item <%= currentPath.startsWith('/depositos') ? 'active' : '' %>">
          <i class="bi bi-building-fill-gear"></i><span>Depositos</span>
        </a>
        <% } %>
        <a href="/insecticidas" class="nav-item <%= currentPath.startsWith('/insecticidas') ? 'active' : '' %>">
          <i class="bi bi-droplet-fill"></i><span>Insecticidas</span>
        </a>
        <a href="/lotes" class="nav-item <%= currentPath.startsWith('/lotes') ? 'active' : '' %>">
          <i class="bi bi-box-seam"></i><span>Lotes</span>
        </a>
        <a href="/unidades-medida" class="nav-item <%= currentPath.startsWith('/unidades-medida') ? 'active' : '' %>">
          <i class="bi bi-rulers"></i><span>Unidades de Medida</span>
        </a>
        <a href="/presentaciones" class="nav-item <%= currentPath.startsWith('/presentaciones') ? 'active' : '' %>">
          <i class="bi bi-box2-heart"></i><span>Presentacion</span>
        </a>
        <% if (userRol === 'admin') { %>
        <a href="/tipos-uso" class="nav-item <%= currentPath.startsWith('/tipos-uso') ? 'active' : '' %>">
          <i class="bi bi-tags-fill"></i><span>Tipos de Uso</span>
        </a>
        <a href="/tipos-movimiento" class="nav-item <%= currentPath.startsWith('/tipos-movimiento') ? 'active' : '' %>">
          <i class="bi bi-arrow-left-right"></i><span>Tipos de Movimiento</span>
        </a>
        <% } %>
      </div>
    </details>
    <% } %>
  </div>

  <div class="sidebar-footer">
    <details class="nav-group nav-group-footer" <%= currentPath === '/perfil' ? 'open' : '' %>>
      <summary class="nav-section-toggle">
        <span><i class="bi bi-person-circle"></i>Perfil</span>
        <i class="bi bi-chevron-down nav-group-chevron"></i>
      </summary>
      <div class="nav-group-items">
        <a href="/perfil" class="nav-item <%= currentPath === '/perfil' ? 'active' : '' %>">
          <i class="bi bi-person-circle"></i><span>Mi Perfil</span>
        </a>
        <a href="/auth/logout" class="nav-item logout-item">
          <i class="bi bi-box-arrow-left"></i><span>Cerrar Sesion</span>
        </a>
      </div>
    </details>
  </div>
</nav>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="main-content">
  <header class="top-header">
    <button class="hamburger" id="sidebarToggle"><i class="bi bi-list"></i></button>
    <div class="header-title">
      <h1 class="page-title"><%= title %></h1>
    </div>
  </header>

  <main class="content-area">
    <% if (flash && flash.success && flash.success.length) { %>
    <div class="alert alert-success alert-dismissible fade show alert-top" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i><%= flash.success[0] %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>
    <% if (flash && flash.error && flash.error.length) { %>
    <div class="alert alert-danger alert-dismissible fade show alert-top" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i><%= flash.error[0] %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <%- body %>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<% if (user) { %>
<script>
  window.SICIS_IDLE_TIMEOUT_MS = <%= sessionIdleMs || 900000 %>;
</script>
<% } %>
<script src="/js/sicis.js"></script>
</body>
</html>


