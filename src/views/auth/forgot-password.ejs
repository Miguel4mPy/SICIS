<% if (errors && errors.length) { %>
<div class="alert alert-danger"><%= errors[0] %></div>
<% } %>
<% if (success && success.length) { %>
<div class="alert alert-success"><%= success[0] %></div>
<% } %>
<p class="text-muted text-center mb-4">Ingrese su correo para recibir instrucciones de restablecimiento.</p>
<form method="POST" action="/auth/forgot-password" class="auth-form">
  <div class="mb-3">
    <label class="form-label">Correo Electrónico</label>
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
      <input type="email" name="email" class="form-control" required placeholder="usuario@senepa.gov.py">
    </div>
  </div>
  <button type="submit" class="btn btn-primary w-100">
    <i class="bi bi-send me-2"></i>Enviar Instrucciones
  </button>
</form>
<div class="auth-links"><a href="/auth/login"><i class="bi bi-arrow-left me-1"></i>Volver al login</a></div>
