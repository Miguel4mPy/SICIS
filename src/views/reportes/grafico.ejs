<% if (typeof print === 'undefined' || !print) { %>
<div class="page-header d-print-none">
  <div>
    <h1 class="page-title"><i class="bi bi-bar-chart-line-fill me-2"></i>Reportes Graficos</h1>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/reportes">Reportes</a></li>
        <li class="breadcrumb-item active">Graficos</li>
      </ol>
    </nav>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <% if (userRol === 'admin' || userRol === 'gerente') { %>
    <div class="dropdown">
      <button class="btn btn-outline-success dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-download me-1"></i>Exportar
      </button>
      <ul class="dropdown-menu dropdown-menu-end">
        <li><a class="dropdown-item" href="/reportes/grafico/exportar?<%= querystring ? `${querystring}&` : '' %>formato=csv">CSV</a></li>
        <li><a class="dropdown-item" href="/reportes/grafico/exportar?<%= querystring ? `${querystring}&` : '' %>formato=xlsx">XLSX</a></li>
        <li><a class="dropdown-item" href="/reportes/grafico/exportar?<%= querystring ? `${querystring}&` : '' %>formato=dbf">DBF</a></li>
      </ul>
    </div>
    <% } %>
    <button type="button" class="btn btn-outline-secondary" data-sicis-print>
      <i class="bi bi-printer me-1"></i>Imprimir
    </button>
  </div>
</div>

<div class="card shadow-sm mb-4 d-print-none">
  <div class="card-body py-3">
    <form method="GET" action="/reportes/grafico" class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="form-label small fw-semibold">Grafico</label>
        <select class="form-select form-select-sm" name="tipo_grafico">
          <option value="movimientos_por_tipo" <%= tipo_grafico === 'movimientos_por_tipo' ? 'selected' : '' %>>Movimientos por tipo</option>
          <option value="stock_por_insecticida" <%= tipo_grafico === 'stock_por_insecticida' ? 'selected' : '' %>>Stock por insecticida</option>
          <option value="movimientos_por_semana" <%= tipo_grafico === 'movimientos_por_semana' ? 'selected' : '' %>>Movimientos por semana</option>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label small fw-semibold">Fecha Desde</label>
        <input type="date" class="form-control form-control-sm" name="fecha_desde" value="<%= filtros.fecha_desde || '' %>">
      </div>
      <div class="col-md-3">
        <label class="form-label small fw-semibold">Fecha Hasta</label>
        <input type="date" class="form-control form-control-sm" name="fecha_hasta" value="<%= filtros.fecha_hasta || '' %>">
      </div>
      <div class="col-md-3">
        <label class="form-label small fw-semibold">Deposito</label>
        <select class="form-select form-select-sm" name="deposito_id">
          <option value="">Todos</option>
          <% depositos.forEach(d => { %>
          <option value="<%= d.id %>" <%= filtros.deposito_id == d.id ? 'selected' : '' %>>[N<%= d.nivel %>] <%= d.codigo %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small fw-semibold">Año</label>
        <select class="form-select form-select-sm" name="anio">
          <% anios.forEach(a => { %>
          <option value="<%= a %>" <%= filtros.anio == a ? 'selected' : '' %>><%= a %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-auto">
        <button type="submit" class="btn btn-warning btn-sm px-4">
          <i class="bi bi-graph-up me-1"></i>Actualizar
        </button>
      </div>
    </form>
  </div>
</div>
<% } %>

<div id="zonaImprimible">
<div class="reporte-membrete d-none d-print-block mb-4">
  <div class="membrete-header">
    <img src="/images/logo-mspbs.png" alt="MSPBS" class="membrete-logo">
    <div class="membrete-info">
      <div class="membrete-institucion">MINISTERIO DE SALUD PUBLICA Y BIENESTAR SOCIAL</div>
      <div class="membrete-dependencia">SERVICIO NACIONAL DE ERRADICACION DEL PALUDISMO - SENEPA</div>
      <div class="membrete-sistema">SICIS - Sistema Informatico de Control de Insecticida</div>
    </div>
    <img src="/images/logo-senepa.png" alt="SENEPA" class="membrete-logo">
  </div>
  <div class="membrete-titulo">REPORTES GRAFICOS - ANALISIS DE INSECTICIDAS</div>
</div>

<div class="card shadow-sm">
  <div class="card-header bg-white py-3">
    <h6 class="mb-0"><i class="bi bi-bar-chart me-2 text-primary"></i>Resultado</h6>
  </div>
  <div class="card-body" style="min-height: <%= tipo_grafico === 'movimientos_por_tipo' ? '620px' : '500px' %>">
    <div style="height: <%= tipo_grafico === 'movimientos_por_tipo' ? '450px' : '470px' %>">
      <canvas id="chartReporte"></canvas>
    </div>
    <div id="multiChartWrap" class="weekly-unit-charts d-none"></div>
    <div id="chartLegendCustom" class="chart-custom-legend d-none"></div>
    <div id="chartEmpty" class="text-center text-muted py-5 d-none">No hay datos para los filtros seleccionados.</div>
  </div>
</div>
<div class="reporte-footer">
  <span>Generado por: <strong><%= user ? `${user.nombre} ${user.apellido}` : '' %></strong></span>
  <span>Fecha y hora: <strong><%= new Date().toLocaleString('es-PY') %></strong></span>
  <span>Reporte: <strong>Graficos</strong></span>
</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
var chartData = <%- safeJson(chartData || { labels: [], datasets: [] }) %>;
var canvas = document.getElementById('chartReporte');
var empty = document.getElementById('chartEmpty');
var multiChartWrap = document.getElementById('multiChartWrap');
var customLegend = document.getElementById('chartLegendCustom');
var isStockPorInsecticida = chartData.chartType === 'stock_por_insecticida';
var isStockPorInsecticidaPorUnidad = isStockPorInsecticida && Array.isArray(chartData.unitGroups);
var isMovimientosPorSemanaInsecticida = chartData.chartType === 'movimientos_por_semana_por_unidad';
var isMovimientosPorTipo = '<%= tipo_grafico %>' === 'movimientos_por_tipo';
var sicisChartPalette = ['#1e88e5', '#43a047', '#f9a825', '#e53935', '#6d4c41', '#00897b', '#8e24aa', '#546e7a'];

function formatoCantidadGrafico(value) {
  return Number(value || 0).toLocaleString('es-PY', {
    minimumFractionDigits: 0,
    maximumFractionDigits: 3
  });
}

function truncateLabel(text, maxLength) {
  var value = String(text || '');
  return value.length > maxLength ? value.slice(0, maxLength - 1) + '...' : value;
}

function getDataTotal(dataset) {
  return (dataset.data || []).reduce(function(sum, item) {
    return sum + Number(item || 0);
  }, 0);
}

function distributeLabelRows(items, minY, maxY, gap) {
  items.sort(function(a, b) {
    return a.targetY - b.targetY;
  });

  items.forEach(function(item, index) {
    item.y = index === 0 ? Math.max(minY, item.targetY) : Math.max(item.targetY, items[index - 1].y + gap);
  });

  for (var i = items.length - 1; i >= 0; i--) {
    items[i].y = i === items.length - 1 ? Math.min(maxY, items[i].y) : Math.min(items[i].y, items[i + 1].y - gap);
  }

  items.forEach(function(item) {
    item.y = Math.max(minY, Math.min(maxY, item.y));
  });
}

function renderMovimientosLegend(data) {
  if (!customLegend || !isMovimientosPorTipo) return;

  var dataset = data.datasets[0] || { data: [] };
  var total = getDataTotal(dataset);
  customLegend.innerHTML = '';
  customLegend.classList.remove('d-none');

  data.labels.forEach(function(label, index) {
    var value = Number(dataset.data[index] || 0);
    if (!value) return;

    var percent = total ? Math.round((value / total) * 100) : 0;
    var item = document.createElement('div');
    item.className = 'chart-custom-legend-item';

    var swatch = document.createElement('span');
    swatch.className = 'chart-custom-legend-swatch';
    swatch.style.backgroundColor = dataset.backgroundColor[index] || sicisChartPalette[index % sicisChartPalette.length];

    var text = document.createElement('span');
    text.textContent = label + ' - ' + formatoCantidadGrafico(value) + ' (' + percent + '%)';

    item.append(swatch, text);
    customLegend.appendChild(item);
  });
}

function applyDatasetStyle(data) {
  if (!data.datasets) return data;

  data.datasets.forEach(function(dataset, datasetIndex) {
    if (isMovimientosPorTipo) {
      dataset.backgroundColor = data.labels.map(function(_, index) {
        return sicisChartPalette[index % sicisChartPalette.length];
      });
      dataset.borderColor = '#ffffff';
      dataset.borderWidth = 2;
      return;
    }

    if (!isStockPorInsecticida) {
      dataset.backgroundColor = sicisChartPalette[datasetIndex % sicisChartPalette.length];
      dataset.borderColor = sicisChartPalette[datasetIndex % sicisChartPalette.length];
      dataset.borderWidth = 1;
    }
  });

  return data;
}

chartData = applyDatasetStyle(chartData);

function styleChartDatasets(data) {
  (data.datasets || []).forEach(function(dataset, datasetIndex) {
    dataset.backgroundColor = sicisChartPalette[datasetIndex % sicisChartPalette.length];
    dataset.borderColor = sicisChartPalette[datasetIndex % sicisChartPalette.length];
    dataset.borderWidth = 1;
    dataset.maxBarThickness = 44;
    dataset.categoryPercentage = 0.58;
    dataset.barPercentage = 0.78;
    dataset.base = 0;
  });
  return data;
}

var sicisDataLabelsPlugin = {
  id: 'sicisDataLabels',
  afterDatasetsDraw(chart) {
    var ctx = chart.ctx;
    var chartArea = chart.chartArea;

    ctx.save();
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.font = '600 10px Barlow, Arial, sans-serif';

    if (isMovimientosPorTipo) {
      if (chart.width < 560) {
        ctx.restore();
        return;
      }

      var dataset = chart.data.datasets[0] || { data: [] };
      var total = getDataTotal(dataset);
      var arcMeta = chart.getDatasetMeta(0);
      var labelItems = [];

      arcMeta.data.forEach(function(element, index) {
        var value = Number(dataset.data[index] || 0);
        if (!value) return;

        var props = element.getProps(['x', 'y', 'startAngle', 'endAngle', 'outerRadius'], true);
        var angle = (props.startAngle + props.endAngle) / 2;
        var percent = total ? Math.round((value / total) * 100) : 0;
        var side = Math.cos(angle) >= 0 ? 'right' : 'left';
        var anchorX = props.x + Math.cos(angle) * (props.outerRadius - 2);
        var anchorY = props.y + Math.sin(angle) * (props.outerRadius - 2);

        labelItems.push({
          side: side,
          anchorX: anchorX,
          anchorY: anchorY,
          lineX: side === 'right' ? props.x + Math.cos(angle) * (props.outerRadius + 22) : props.x + Math.cos(angle) * (props.outerRadius + 22),
          textX: side === 'right' ? props.x + Math.cos(angle) * (props.outerRadius + 30) : props.x + Math.cos(angle) * (props.outerRadius + 30),
          targetY: props.y + Math.sin(angle) * (props.outerRadius + 18),
          title: truncateLabel(chart.data.labels[index], 15),
          value: formatoCantidadGrafico(value) + ' (' + percent + '%)'
        });
      });

      ['left', 'right'].forEach(function(side) {
        var sideItems = labelItems.filter(function(item) {
          return item.side === side;
        });
        distributeLabelRows(sideItems, chartArea.top + 16, chartArea.bottom - 16, 28);

        sideItems.forEach(function(item) {
          ctx.textAlign = side === 'right' ? 'left' : 'right';
          ctx.textBaseline = 'middle';
          ctx.strokeStyle = '#94a3b8';
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(item.anchorX, item.anchorY);
          ctx.lineTo(item.lineX, item.y);
          ctx.stroke();

          ctx.font = '600 10px Barlow, Arial, sans-serif';
          ctx.fillStyle = '#1f2937';
          ctx.fillText(item.title, item.textX, item.y - 7);
          ctx.font = '700 10px Barlow, Arial, sans-serif';
          ctx.fillText(item.value, item.textX, item.y + 7);
        });
      });

      ctx.restore();
      return;
    }

    if (isStockPorInsecticida) {
      var outsideLabelSlots = {};

      chart.data.datasets.forEach(function(dataset, datasetIndex) {
        var meta = chart.getDatasetMeta(datasetIndex);
        if (!meta || meta.hidden) return;

        meta.data.forEach(function(element, index) {
          var value = Number(dataset.data[index] || 0);
          if (!value || !dataset.meta) return;

          var props = element.getProps(['x', 'y', 'base', 'width'], true);
          var segmentHeight = Math.abs(props.base - props.y);
          var segmentWidth = Math.max(props.width || 0, 0);
          var hasRoomInside = segmentHeight >= 48 && segmentWidth >= 86;
          var estado = dataset.meta.estado_vencimiento || 'Sin estado';

          var isWarning = estado === 'Proximo';
          if (hasRoomInside) {
            ctx.textAlign = 'center';
            ctx.fillStyle = isWarning ? '#1f2937' : '#ffffff';

            var lines = [
              'Vto.: ' + dataset.meta.vencimiento,
              'Estado: ' + estado
            ];
            var y = props.y + (props.base - props.y) / 2 - ((lines.length - 1) * 6);
            lines.forEach(function(line, lineIndex) {
              ctx.fillText(line, props.x, y + (lineIndex * 12));
            });
            return;
          }

          var slotKey = String(index);
          outsideLabelSlots[slotKey] = outsideLabelSlots[slotKey] || 0;
          var slot = outsideLabelSlots[slotKey]++;
          var preferredY = props.y - 34 - (slot * 46);
          var labelY = preferredY < chartArea.top + 28 ? chartArea.top + 28 + (slot * 46) : preferredY;
          var outsideLines = [
            'Stock: ' + formatoCantidadGrafico(value) + ' ' + (dataset.meta.unidad_medida || ''),
            'Vto.: ' + dataset.meta.vencimiento,
            'Estado: ' + estado
          ];
          var labelWidth = 132;
          var labelHeight = 46;
          var labelTop = labelY - 18;
          var labelLeft = props.x - (labelWidth / 2);
          var labelBottom = labelTop + labelHeight;

          ctx.textAlign = 'center';
          ctx.fillStyle = 'rgba(255,255,255,.94)';
          ctx.strokeStyle = '#cbd5e1';
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.roundRect(labelLeft, labelTop, labelWidth, labelHeight, 4);
          ctx.fill();
          ctx.stroke();

          ctx.strokeStyle = '#94a3b8';
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(props.x, Math.max(props.y, chartArea.top + 4));
          ctx.lineTo(props.x, labelBottom);
          ctx.stroke();

          ctx.font = '600 10px Barlow, Arial, sans-serif';
          ctx.fillStyle = '#1f2937';
          outsideLines.forEach(function(line, lineIndex) {
            ctx.fillText(line, props.x, labelTop + 12 + (lineIndex * 12));
          });
        });
      });
    }

    if (isMovimientosPorSemanaInsecticida) {
      chart.data.datasets.forEach(function(dataset, datasetIndex) {
        var meta = chart.getDatasetMeta(datasetIndex);
        if (!meta || meta.hidden) return;

        meta.data.forEach(function(element, index) {
          var value = Number(dataset.data[index] || 0);
          if (!value) return;

          var props = element.getProps(['x', 'y', 'base'], true);
          var segmentHeight = Math.abs(props.base - props.y);
          if (segmentHeight < 18) return;

          ctx.fillStyle = '#ffffff';
          ctx.font = '700 10px Barlow, Arial, sans-serif';
          ctx.textAlign = 'center';
          var unidad = dataset.meta?.unidad_medida || '';
          ctx.fillText(formatoCantidadGrafico(value) + (unidad ? ' ' + unidad : ''), props.x, props.y + (props.base - props.y) / 2);
        });
      });
    } else if (!isStockPorInsecticida) {
      chart.data.datasets.forEach(function(dataset, datasetIndex) {
        var meta = chart.getDatasetMeta(datasetIndex);
        if (!meta || meta.hidden) return;

        meta.data.forEach(function(element, index) {
          var value = Number(dataset.data[index] || 0);
          if (!value) return;

          var props = element.getProps(['x', 'y'], true);
          ctx.fillStyle = '#1f2937';
          ctx.font = '700 10px Barlow, Arial, sans-serif';
          ctx.fillText(formatoCantidadGrafico(value), props.x, Math.max(chartArea.top + 10, props.y - 10));
        });
      });
    }

    ctx.restore();
  }
};

if (!chartData.labels || chartData.labels.length === 0) {
  canvas.classList.add('d-none');
  empty.classList.remove('d-none');
} else if (isStockPorInsecticidaPorUnidad) {
  canvas.parentElement.classList.add('d-none');
  multiChartWrap.classList.remove('d-none');
  multiChartWrap.innerHTML = '';

  chartData.unitGroups.forEach(function(group) {
    var panel = document.createElement('div');
    panel.className = 'weekly-unit-chart-panel';

    var title = document.createElement('div');
    title.className = 'weekly-unit-chart-title';
    title.textContent = 'Unidad: ' + (group.unidad || 'Sin unidad');

    var labels = group.labels || [];
    var datasets = group.datasets || [];
    var totalsByLabel = labels.map(function(_, labelIndex) {
      return datasets.reduce(function(sum, dataset) {
        return sum + Number((dataset.data || [])[labelIndex] || 0);
      }, 0);
    });
    var maxValue = totalsByLabel.reduce(function(max, total) {
      return Math.max(max, total);
    }, 0);
    var scaleMax = maxValue ? maxValue * 1.12 : 1;

    var chart = document.createElement('div');
    chart.className = 'weekly-css-chart';

    var axis = document.createElement('div');
    axis.className = 'weekly-css-axis';
    [1, .75, .5, .25, 0].forEach(function(ratio) {
      var tick = document.createElement('span');
      tick.textContent = formatoCantidadGrafico(scaleMax * ratio);
      axis.appendChild(tick);
    });

    var plot = document.createElement('div');
    plot.className = 'weekly-css-plot';
    [0, 1, 2, 3, 4].forEach(function() {
      var line = document.createElement('span');
      line.className = 'weekly-css-gridline';
      plot.appendChild(line);
    });

    labels.forEach(function(label, labelIndex) {
      var category = document.createElement('div');
      category.className = 'weekly-css-week';

      var bars = document.createElement('div');
      bars.className = 'weekly-css-bars';

      var total = totalsByLabel[labelIndex] || 0;
      var stack = document.createElement('div');
      stack.className = 'stock-css-stack';
      stack.style.height = Math.max(2, (total / scaleMax) * 100) + '%';

      datasets.forEach(function(dataset) {
        var value = Number((dataset.data || [])[labelIndex] || 0);
        if (!value) return;

        var segment = document.createElement('div');
        segment.className = 'stock-css-segment';
        segment.style.height = (value / total) * 100 + '%';
        segment.style.backgroundColor = dataset.backgroundColor || '#1e88e5';
        segment.title = dataset.label;

        if ((value / total) >= .18) {
          var segmentText = document.createElement('span');
          segmentText.className = 'stock-css-segment-label';
          segmentText.textContent = formatoCantidadGrafico(value);
          segment.appendChild(segmentText);
        }
        stack.appendChild(segment);
      });

      var valueLabel = document.createElement('span');
      valueLabel.className = 'weekly-css-bar-value stock-css-total-label';
      valueLabel.textContent = total ? formatoCantidadGrafico(total) : '';
      stack.appendChild(valueLabel);
      bars.appendChild(stack);

      var categoryLabel = document.createElement('div');
      categoryLabel.className = 'weekly-css-week-label';
      categoryLabel.textContent = label;
      category.append(bars, categoryLabel);
      plot.appendChild(category);
    });

    var legend = document.createElement('div');
    legend.className = 'weekly-css-legend';
    datasets.forEach(function(dataset) {
      var item = document.createElement('div');
      item.className = 'weekly-css-legend-item';
      var swatch = document.createElement('span');
      swatch.className = 'weekly-css-legend-swatch';
      swatch.style.backgroundColor = dataset.backgroundColor || '#1e88e5';
      var text = document.createElement('span');
      text.textContent = dataset.label;
      item.append(swatch, text);
      legend.appendChild(item);
    });

    chart.append(axis, plot);
    panel.append(title, chart, legend);
    multiChartWrap.appendChild(panel);
  });
} else if (isMovimientosPorSemanaInsecticida && Array.isArray(chartData.unitGroups)) {
  canvas.parentElement.classList.add('d-none');
  multiChartWrap.classList.remove('d-none');
  multiChartWrap.innerHTML = '';

  chartData.unitGroups.forEach(function(group, groupIndex) {
    var panel = document.createElement('div');
    panel.className = 'weekly-unit-chart-panel';

    var title = document.createElement('div');
    title.className = 'weekly-unit-chart-title';
    title.textContent = 'Unidad: ' + (group.unidad || 'Sin unidad');

    var labels = group.labels || [];
    var datasets = group.datasets || [];
    var maxValue = datasets.reduce(function(max, dataset) {
      return Math.max(max, ...(dataset.data || []).map(value => Number(value || 0)));
    }, 0);
    var scaleMax = maxValue ? maxValue * 1.12 : 1;

    var chart = document.createElement('div');
    chart.className = 'weekly-css-chart';

    var axis = document.createElement('div');
    axis.className = 'weekly-css-axis';
    [1, .75, .5, .25, 0].forEach(function(ratio) {
      var tick = document.createElement('span');
      tick.textContent = formatoCantidadGrafico(scaleMax * ratio);
      axis.appendChild(tick);
    });

    var plot = document.createElement('div');
    plot.className = 'weekly-css-plot';
    [0, 1, 2, 3, 4].forEach(function() {
      var line = document.createElement('span');
      line.className = 'weekly-css-gridline';
      plot.appendChild(line);
    });

    labels.forEach(function(label, weekIndex) {
      var week = document.createElement('div');
      week.className = 'weekly-css-week';

      var bars = document.createElement('div');
      bars.className = 'weekly-css-bars';

      datasets.forEach(function(dataset, datasetIndex) {
        var value = Number(dataset.data[weekIndex] || 0);
        var bar = document.createElement('div');
        bar.className = 'weekly-css-bar';
        bar.style.height = Math.max(2, (value / scaleMax) * 100) + '%';
        bar.style.backgroundColor = sicisChartPalette[datasetIndex % sicisChartPalette.length];
        bar.title = dataset.label + ': ' + formatoCantidadGrafico(value) + ' ' + (group.unidad || '');

        var valueLabel = document.createElement('span');
        valueLabel.className = 'weekly-css-bar-value';
        valueLabel.textContent = value ? formatoCantidadGrafico(value) : '';
        bar.appendChild(valueLabel);
        bars.appendChild(bar);
      });

      var weekLabel = document.createElement('div');
      weekLabel.className = 'weekly-css-week-label';
      weekLabel.textContent = label;
      week.append(bars, weekLabel);
      plot.appendChild(week);
    });

    var legend = document.createElement('div');
    legend.className = 'weekly-css-legend';
    datasets.forEach(function(dataset, datasetIndex) {
      var item = document.createElement('div');
      item.className = 'weekly-css-legend-item';
      var swatch = document.createElement('span');
      swatch.className = 'weekly-css-legend-swatch';
      swatch.style.backgroundColor = sicisChartPalette[datasetIndex % sicisChartPalette.length];
      var text = document.createElement('span');
      text.textContent = dataset.label;
      item.append(swatch, text);
      legend.appendChild(item);
    });

    chart.append(axis, plot);
    panel.append(title, chart, legend);
    multiChartWrap.appendChild(panel);
  });
} else {
  if (window.sicisReporteChart) window.sicisReporteChart.destroy();
  window.sicisReporteChart = new Chart(canvas, {
    type: '<%= tipo_grafico === 'movimientos_por_tipo' ? 'doughnut' : 'bar' %>',
    data: chartData,
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        title: {
          display: isStockPorInsecticida,
          text: 'Stock por insecticida apilado por lote',
          color: '#1f2937',
          font: { size: 15, weight: '700' },
          padding: { bottom: 16 }
        },
        subtitle: {
          display: isStockPorInsecticida,
          text: 'Columna: insecticida | Segmento: lote con stock, vencimiento y estado',
          color: '#64748b',
          font: { size: 11 },
          padding: { bottom: 8 }
        },
        legend: {
          display: !isMovimientosPorTipo,
          position: 'bottom',
          align: 'center',
          labels: {
            boxWidth: 10,
            boxHeight: 10,
            padding: 12,
            usePointStyle: true,
            pointStyle: 'rectRounded',
            font: { size: isStockPorInsecticida ? 10 : 12 },
            generateLabels: function(chart) {
              var labels = Chart.defaults.plugins.legend.labels.generateLabels(chart);
              if (isStockPorInsecticida) {
                return labels.map(function(label) {
                  var dataset = chart.data.datasets[label.datasetIndex] || {};
                  var meta = dataset.meta || {};
                  var value = Number((dataset.data || []).reduce(function(sum, item) {
                    return sum + Number(item || 0);
                  }, 0));
                  label.text = truncateLabel(
                    'Stock ' + formatoCantidadGrafico(value) + ' ' + (meta.unidad_medida || '') + ' | Vto. ' + (meta.vencimiento || '-') + ' | Estado: ' + (meta.estado_vencimiento || '-'),
                    74
                  );
                  return label;
                });
              }

              if (!isMovimientosPorTipo) {
                return labels.map(function(label) {
                  label.text = truncateLabel(label.text, isMovimientosPorSemanaInsecticida ? 36 : 28);
                  return label;
                });
              }

              var dataset = chart.data.datasets[0] || { data: [] };
              var total = getDataTotal(dataset);
              return labels.map(function(label) {
                var value = Number(dataset.data[label.index] || 0);
                var percent = total ? Math.round((value / total) * 100) : 0;
                label.text = truncateLabel(label.text, 20) + ' - ' + formatoCantidadGrafico(value) + ' (' + percent + '%)';
                return label;
              });
            }
          }
        },
        tooltip: {
          callbacks: {
            title: function(items) {
              return items[0]?.label || '';
            },
            label: function(context) {
              if (isMovimientosPorTipo) {
                var value = Number(context.raw || 0);
                var total = getDataTotal(context.dataset);
                var percent = total ? Math.round((value / total) * 100) : 0;
                return context.label + ': ' + formatoCantidadGrafico(value) + ' (' + percent + '%)';
              }

              if (!isStockPorInsecticida || !context.dataset.meta) {
                var unidad = context.dataset.meta?.unidad_medida || '';
                return context.dataset.label + ': ' + formatoCantidadGrafico(context.parsed.y || context.raw) + (unidad ? ' ' + unidad : '');
              }

              var meta = context.dataset.meta;
              return [
                'Stock: ' + formatoCantidadGrafico(context.raw) + ' ' + (meta.unidad_medida || ''),
                'Vencimiento: ' + meta.vencimiento,
                'Estado: ' + meta.estado_vencimiento
              ];
            }
          }
        }
      },
      layout: {
        padding: {
          top: isMovimientosPorTipo ? 16 : (isStockPorInsecticida ? 34 : 18),
          bottom: isMovimientosPorTipo ? 10 : 8,
          left: isMovimientosPorTipo ? 104 : 8,
          right: isMovimientosPorTipo ? 104 : 8
        }
      },
      radius: isMovimientosPorTipo ? '56%' : undefined,
      cutout: isMovimientosPorTipo ? '54%' : undefined,
      scales: '<%= tipo_grafico === 'movimientos_por_tipo' ? 'none' : 'linear' %>' === 'none'
        ? {}
        : {
            x: {
              stacked: isStockPorInsecticida,
              title: {
                display: isStockPorInsecticida || isMovimientosPorSemanaInsecticida,
                text: isMovimientosPorSemanaInsecticida ? 'Semana epidemiologica' : 'Insecticida',
                color: '#334155',
                font: { size: 12, weight: '700' }
              }
            },
            y: {
              beginAtZero: true,
              stacked: isStockPorInsecticida,
              title: {
                display: isStockPorInsecticida || isMovimientosPorSemanaInsecticida,
                text: isMovimientosPorSemanaInsecticida ? 'Cantidad movida (ver unidad en cada serie)' : 'Stock total',
                color: '#334155',
                font: { size: 12, weight: '700' }
              },
              ticks: { callback: value => formatoCantidadGrafico(value) }
            }
          }
    },
    plugins: [sicisDataLabelsPlugin]
  });
  renderMovimientosLegend(chartData);
}
</script>

