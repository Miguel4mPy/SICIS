<%
  const totalMovimientos = statsMovs.reduce((a, b) => a + parseInt(b.total || 0, 10), 0);
  const totalDepositos = statsDepositos.reduce((a, b) => a + parseInt(b.total || 0, 10), 0);
  const tiposStock = { focal: 'Focal', espacial: 'Espacial', residual: 'Residual', larvicida: 'Larvicida' };
  const coloresStock = { focal: '#dc3545', espacial: '#0d6efd', residual: '#198754', larvicida: '#fd7e14' };
  const maxStock = Math.max(...statsStock.map(x => parseFloat(x.total || 0)), 1);
%>

<div class="dashboard-page">
  <section class="dashboard-section">
    <div class="dashboard-section-header">
      <div>
        <span class="dashboard-eyebrow">Resumen</span>
        <h2>Estado general</h2>
      </div>
    </div>

    <div class="dashboard-summary-grid">
      <div class="dashboard-summary-card summary-blue">
        <div class="summary-icon"><i class="bi bi-arrow-left-right"></i></div>
        <div class="summary-content">
          <div class="summary-value"><%= totalMovimientos %></div>
          <div class="summary-label">Movimientos</div>
          <div class="summary-meta">Ultimos 30 dias</div>
        </div>
      </div>

      <div class="dashboard-summary-card summary-green">
        <div class="summary-icon"><i class="bi bi-building"></i></div>
        <div class="summary-content">
          <div class="summary-value"><%= totalDepositos %></div>
          <div class="summary-label">Depositos Activos</div>
          <div class="summary-meta">Actualmente habilitados</div>
        </div>
      </div>

      <div class="dashboard-summary-card summary-orange">
        <div class="summary-icon"><i class="bi bi-droplet-fill"></i></div>
        <div class="summary-content">
          <div class="summary-value"><%= statsStock.length %></div>
          <div class="summary-label">Tipos de Insecticidas en Stock</div>
          <div class="summary-meta">Con existencia disponible</div>
        </div>
      </div>

      <div class="dashboard-summary-card summary-red">
        <div class="summary-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <div class="summary-content">
          <div class="summary-value"><%= lotesPorVencer.length %></div>
          <div class="summary-label">Lotes por vencer</div>
          <div class="summary-meta">Proximos 90 dias</div>
        </div>
      </div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="dashboard-section-header">
      <div>
        <span class="dashboard-eyebrow">Lotes Proximos a Vencer</span>
        <h2>Seguimiento de vencimientos</h2>
      </div>
      <% if (userRol === 'admin' || userRol === 'gerente') { %>
        <a href="/lotes" class="btn btn-xs btn-outline-secondary">Ver todos</a>
      <% } %>
    </div>

    <% if (lotesPorVencer.length === 0) { %>
      <div class="dashboard-empty-card">No hay lotes proximos a vencer</div>
    <% } else { %>
      <div class="dashboard-card-grid lotes-card-grid">
        <% for (const l of lotesPorVencer) { %>
          <% const dias = Math.floor((new Date(l.fecha_vencimiento) - new Date()) / 86400000); %>
          <article class="dashboard-info-card lote-alert-card <%= dias < 30 ? 'is-critical' : 'is-warning' %>">
            <div class="info-card-topline">
              <code><%= l.codigo_lote %></code>
              <span class="status-pill <%= dias < 30 ? 'status-danger' : 'status-warning' %>">
                <%= dias < 0 ? 'Vencido' : `${dias} dias` %>
              </span>
            </div>
            <h3><%= l.ins_nombre %></h3>
            <div class="info-card-meta">
              <span><i class="bi bi-calendar-event"></i><%= formatearFecha(l.fecha_vencimiento) %></span>
              <span><i class="bi bi-box-seam"></i><%= parseFloat(l.stock || 0).toFixed(2) %> en stock</span>
            </div>
          </article>
        <% } %>
      </div>
    <% } %>
  </section>

  <section class="dashboard-section">
    <div class="dashboard-section-header">
      <div>
        <span class="dashboard-eyebrow">Stock Actual por Insecticida</span>
        <h2>Existencias disponibles</h2>
      </div>
      <% if (userRol === 'admin' || userRol === 'gerente') { %>
        <a href="/reportes/stock" class="btn btn-xs btn-outline-secondary">Ver reporte</a>
      <% } %>
    </div>

    <% if (statsStock.length === 0) { %>
      <div class="dashboard-empty-card">No hay stock registrado</div>
    <% } else { %>
      <div class="dashboard-card-grid stock-card-grid">
        <% for (const s of statsStock) { %>
          <% const usos = Array.isArray(s.tipo_usos) && s.tipo_usos.length ? s.tipo_usos : [s.tipo_uso]; %>
          <% const stockTotal = parseFloat(s.total || 0); %>
          <article class="dashboard-info-card stock-dashboard-card">
            <div class="info-card-topline">
              <code><%= s.codigo %></code>
              <span class="stock-unit"><%= s.unidad_medida %></span>
            </div>
            <h3><a href="/insecticidas/<%= s.id %>" class="link-sicis"><%= s.nombre %></a></h3>
            <div class="stock-card-value"><%= stockTotal.toFixed(2) %></div>
            <div class="sti-bar">
              <div class="sti-bar-fill" style="width: <%= Math.min(100, (stockTotal / maxStock) * 100) %>%; background: <%= coloresStock[s.tipo_uso] || '#66788a' %>"></div>
            </div>
            <div class="stock-card-badges">
              <% for (const uso of usos) { %>
                <span class="badge-tipo-uso badge-<%= uso %>"><%= tiposStock[uso] || uso %></span>
              <% } %>
            </div>
          </article>
        <% } %>
      </div>
    <% } %>
  </section>

  <section class="dashboard-section">
    <div class="dashboard-section-header">
      <div>
        <span class="dashboard-eyebrow">Ultimos Movimientos</span>
        <h2>Actividad reciente</h2>
      </div>
      <% if (userRol === 'admin' || userRol === 'gerente') { %>
        <a href="/movimientos" class="btn btn-xs btn-outline-secondary">Ver todos</a>
      <% } %>
    </div>

    <% if (movRecientes.length === 0) { %>
      <div class="dashboard-empty-card">No hay movimientos registrados</div>
    <% } else { %>
      <div class="dashboard-card-grid movements-card-grid">
        <% for (const m of movRecientes) { %>
          <article class="dashboard-info-card movement-dashboard-card">
            <div class="info-card-topline">
              <a href="/movimientos/<%= m.id %>" class="link-sicis"><code><%= m.numero_mov %></code></a>
              <span class="badge-tipo-mov badge-mov-<%= m.tipo_movimiento %>"><%= tipoMovimientoLabel(m.tipo_movimiento) %></span>
            </div>
            <h3><%= m.ins_nombre %></h3>
            <div class="movement-amount">
              <%= parseFloat(m.cantidad || 0).toFixed(2) %>
              <small><%= m.unidad_medida %></small>
            </div>
            <div class="movement-route">
              <span><i class="bi bi-box-arrow-up-right"></i><%= m.origen || 'Sin origen' %></span>
              <span><i class="bi bi-box-arrow-in-down-right"></i><%= m.destino || 'Sin destino' %></span>
            </div>
            <div class="info-card-footer">
              <span><i class="bi bi-calendar3"></i><%= formatearFecha(m.fecha_movimiento) %></span>
              <span><i class="bi bi-person"></i><%= m.usuario %></span>
            </div>
          </article>
        <% } %>
      </div>
    <% } %>
  </section>
</div>

<div class="quick-actions">
  <a href="/movimientos/nuevo" class="qa-btn qa-primary" title="Nuevo Movimiento">
    <i class="bi bi-plus-lg"></i>
  </a>
</div>
