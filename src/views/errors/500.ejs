<div class="d-flex align-items-center justify-content-center" style="min-height: 60vh;">
  <div class="text-center">
    <div class="error-code mb-3" style="background: linear-gradient(135deg, #dc3545, #b02a37);">500</div>
    <h2 class="fw-bold mb-2">Error interno del servidor</h2>
    <p class="text-muted mb-4">
      Ocurrio un error inesperado.<br>
      Por favor intenta nuevamente en unos momentos.
    </p>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger text-start mb-4" style="max-width:600px;margin:0 auto;">
      <strong>Error:</strong><br>
      <code><%= error %></code>
    </div>
    <% } %>
    <div class="d-flex gap-3 justify-content-center">
      <a href="javascript:history.back()" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Volver atras
      </a>
      <a href="/dashboard" class="btn btn-primary">
        <i class="bi bi-house-fill me-2"></i>Ir al inicio
      </a>
    </div>
  </div>
</div>

<style>
.error-code {
  font-size: 6rem;
  font-weight: 900;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}
</style>
