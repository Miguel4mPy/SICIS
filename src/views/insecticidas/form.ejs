<% if (errors && errors.length) { %>
<div class="alert alert-danger"><%= errors[0] %></div>
<% } %>
<div class="row justify-content-center"><div class="col-xl-7">
<div class="card-sicis">
  <div class="card-sicis-header"><i class="bi bi-droplet me-2"></i><%= insecticida.id ? 'Editar' : 'Nuevo' %> Insecticida</div>
  <div class="card-sicis-body">
    <form method="POST" action="/insecticidas<%= insecticida.id ? '/' + insecticida.id : '' %>">
      <div class="row g-3">
        <div class="col-md-5">
          <label class="form-label required">Código</label>
          <input type="text" name="codigo" class="form-control" value="<%= insecticida.codigo || '' %>" required placeholder="INS-FOC-003" <%= insecticida.id ? 'readonly' : '' %>>
        </div>
        <div class="col-md-7">
          <label class="form-label required">Nombre del Insecticida</label>
          <input type="text" name="nombre" class="form-control" value="<%= insecticida.nombre || '' %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label required">Tipo de Uso</label>
          <select name="tipo_uso" class="form-select" required>
            <% for (const t of ['focal', 'espacial', 'residual', 'larvicida']) { %>
            <option value="<%= t %>" <%= insecticida.tipo_uso === t ? 'selected' : '' %>><%= t.charAt(0).toUpperCase()+t.slice(1) %></option>
            <% } %>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label required">Unidad de Medida</label>
          <select name="unidad_medida" class="form-select" required>
            <% for (const u of ['litro','kg','ml','gr','unidad']) { %>
            <option value="<%= u %>" <%= insecticida.unidad_medida === u ? 'selected' : '' %>><%= u %></option>
            <% } %>
          </select>
        </div>
        <div class="col-12">
          <label class="form-label">Descripción</label>
          <textarea name="descripcion" class="form-control" rows="2"><%= insecticida.descripcion || '' %></textarea>
        </div>
        <% if (insecticida.id) { %>
        <div class="col-12"><div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" name="activo" id="activo" <%= insecticida.activo ? 'checked' : '' %>>
          <label class="form-check-label" for="activo">Insecticida activo</label>
        </div></div>
        <% } %>
      </div>
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Guardar</button>
        <a href="/insecticidas" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
</div></div>
