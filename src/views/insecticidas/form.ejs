<% if (errors && errors.length) { %>
<div class="alert alert-danger"><%= errors[0] %></div>
<% } %>
<div class="row justify-content-center"><div class="col-xl-7">
<div class="card-sicis">
  <div class="card-sicis-header"><i class="bi bi-droplet me-2"></i><%= insecticida.id ? 'Editar' : 'Nuevo' %> Insecticida</div>
  <div class="card-sicis-body">
    <form method="POST" action="/insecticidas<%= insecticida.id ? '/' + insecticida.id : '' %>">
      <div class="row g-3">
        <div class="col-md-5">
          <label class="form-label required">Código</label>
          <input type="text" name="codigo" class="form-control" value="<%= insecticida.codigo || '' %>" required placeholder="INS-FOC-003">
        </div>
        <div class="col-md-7">
          <label class="form-label required">Nombre del Insecticida</label>
          <input type="text" name="nombre" class="form-control" value="<%= insecticida.nombre || '' %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label required">Tipos de Uso</label>
          <% const tiposSeleccionados = Array.isArray(insecticida.tipo_usos) && insecticida.tipo_usos.length ? insecticida.tipo_usos : (insecticida.tipo_uso ? [insecticida.tipo_uso] : []); %>
          <div class="tipo-uso-options">
            <% for (const tipo of (tiposUso || []).filter(t => t.activo || tiposSeleccionados.includes(t.codigo))) { %>
            <label class="tipo-uso-option">
              <input type="checkbox" name="tipo_usos" value="<%= tipo.codigo %>" <%= tiposSeleccionados.includes(tipo.codigo) ? 'checked' : '' %>>
              <span class="badge-tipo-uso badge-<%= tipo.codigo %>"><%= tipo.nombre %></span>
            </label>
            <% } %>
          </div>
          <div class="form-text">Puede seleccionar uno o varios usos para el mismo insecticida.</div>
        </div>
        <div class="col-md-6">
          <label class="form-label required">Unidad de Medida</label>
          <select name="unidad_medida" class="form-select" required>
            <% for (const u of (unidadesMedida || []).filter(x => x.activo || insecticida.unidad_medida === x.codigo)) { %>
            <option value="<%= u.codigo %>" <%= insecticida.unidad_medida === u.codigo ? 'selected' : '' %>><%= u.nombre %> (<%= u.abreviatura %>)</option>
            <% } %>
          </select>
        </div>
        <div class="col-12">
          <label class="form-label">Descripción</label>
          <textarea name="descripcion" class="form-control" rows="2"><%= insecticida.descripcion || '' %></textarea>
        </div>
        <% if (insecticida.id) { %>
        <div class="col-12"><div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" name="activo" id="activo" <%= insecticida.activo ? 'checked' : '' %>>
          <label class="form-check-label" for="activo">Insecticida activo</label>
        </div></div>
        <% } %>
      </div>
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Guardar</button>
        <a href="/insecticidas" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
</div></div>
