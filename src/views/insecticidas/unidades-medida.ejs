<div class="page-header">
  <div>
    <h1 class="page-title"><i class="bi bi-rulers me-2"></i>Unidades de Medida</h1>
    <p class="text-muted mb-0">Catalogo utilizado por los lotes y reportes de stock.</p>
  </div>
</div>

<% if (success && success.length) { %>
<div class="alert alert-success"><i class="bi bi-check-circle-fill me-2"></i><%= success[0] %></div>
<% } %>
<% if (error && error.length) { %>
<div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error[0] %></div>
<% } %>

<div class="row g-3">
  <div class="col-lg-4">
    <div class="card-sicis">
      <div class="card-sicis-header"><i class="bi bi-plus-circle me-2"></i>Nueva Unidad</div>
      <div class="card-sicis-body">
        <form method="POST" action="/unidades-medida">
          <div class="mb-3">
            <label class="form-label required">Codigo</label>
            <input name="codigo" class="form-control" required maxlength="20" placeholder="ej: bidon">
            <div class="form-text">Solo letras, numeros, guion o guion bajo. No se edita luego.</div>
          </div>
          <div class="mb-3">
            <label class="form-label required">Nombre</label>
            <input name="nombre" class="form-control" required maxlength="80" placeholder="Bidon">
          </div>
          <div class="mb-3">
            <label class="form-label required">Abreviatura</label>
            <input name="abreviatura" class="form-control" required maxlength="20" placeholder="bidon">
          </div>
          <div class="mb-3">
            <label class="form-label">Orden</label>
            <input type="number" name="orden" class="form-control" value="0" step="1">
          </div>
          <button class="btn btn-primary w-100" type="submit">
            <i class="bi bi-check-circle me-1"></i>Crear unidad
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card-sicis">
      <div class="card-sicis-header"><i class="bi bi-rulers me-2"></i>Catalogo de Unidades</div>
      <div class="card-sicis-body p-0">
        <div class="table-responsive">
          <table class="table table-sicis unidades-table mb-0">
            <thead>
              <tr>
                <th>Codigo</th>
                <th>Nombre</th>
                <th>Abreviatura</th>
                <th>Orden</th>
                <th>Uso</th>
                <th>Activo</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% for (const u of unidades) { %>
              <% const formId = `unidad_${u.codigo.replace(/[^a-zA-Z0-9_-]/g, '_')}`; %>
              <tr>
                  <td>
                    <form id="<%= formId %>" method="POST" action="/unidades-medida/<%= u.codigo %>"></form>
                    <code><%= u.codigo %></code>
                  </td>
                  <td><input form="<%= formId %>" name="nombre" class="form-control form-control-sm" value="<%= u.nombre %>" required></td>
                  <td><input form="<%= formId %>" name="abreviatura" class="form-control form-control-sm" value="<%= u.abreviatura %>" required></td>
                  <td><input form="<%= formId %>" type="number" name="orden" class="form-control form-control-sm" value="<%= u.orden %>" step="1" style="max-width:90px"></td>
                  <td><span class="badge bg-light text-dark border"><%= totalPorUnidad[u.codigo] || 0 %> lote(s)</span></td>
                  <td>
                    <div class="form-check form-switch">
                      <input form="<%= formId %>" class="form-check-input" type="checkbox" name="activo" <%= u.activo ? 'checked' : '' %>>
                    </div>
                  </td>
                  <td>
                    <div class="btn-group btn-group-sm">
                      <button form="<%= formId %>" class="btn btn-outline-primary" type="submit" title="Guardar">
                        <i class="bi bi-check-lg"></i>
                      </button>
                      <form method="POST" action="/unidades-medida/<%= u.codigo %>/eliminar" class="d-inline" data-confirm="Desactivar la unidad <%= u.nombre %>?">
                        <button class="btn btn-outline-danger" type="submit" title="Eliminar">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
