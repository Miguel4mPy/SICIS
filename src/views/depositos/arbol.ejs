<div class="page-actions mb-3">
  <a href="/depositos" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

<div class="card-sicis">
  <div class="card-sicis-header">
    <i class="bi bi-diagram-3 me-2"></i>Arbol Jerarquico de Depositos
  </div>
  <div class="card-sicis-body">
    <%
      const hijosPorPadre = new Map();
      const porId = new Map(depositos.map(d => [d.id, d]));
      for (const d of depositos) {
        const padre = d.deposito_padre_id || 0;
        if (!hijosPorPadre.has(padre)) hijosPorPadre.set(padre, []);
        hijosPorPadre.get(padre).push(d);
      }
      const raices = depositos.filter(d => !d.deposito_padre_id || !porId.has(d.deposito_padre_id));
      const renderNodo = (d) => {
        const hijos = hijosPorPadre.get(d.id) || [];
    %>
      <li>
        <div class="org-node org-node-n<%= d.nivel %>">
          <div class="org-node-icon">
            <i class="bi bi-<%= d.nivel === 1 ? 'building-fill' : d.nivel === 2 ? 'building' : 'geo-alt-fill' %>"></i>
          </div>
          <div class="org-node-body">
            <a href="/depositos/<%= d.id %>" class="org-node-title"><%= d.nombre %></a>
            <div class="org-node-code"><code><%= d.codigo %></code></div>
            <div class="org-node-meta">
              <span class="nivel-badge nivel-<%= d.nivel %>">Nivel <%= d.nivel %></span>
              <span><%= tipoDepositoLabel(d.tipo) %></span>
            </div>
          </div>
        </div>
        <% if (hijos.length) { %>
        <ul>
          <% for (const h of hijos) { %>
            <%- renderNodo(h) %>
          <% } %>
        </ul>
        <% } %>
      </li>
    <%
      };
    %>

    <% if (depositos.length === 0) { %>
      <p class="text-muted text-center py-4 mb-0">No hay depositos activos para mostrar.</p>
    <% } else { %>
      <div class="org-chart-toolbar" data-org-toolbar>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-org-zoom-out title="Alejar">
          <i class="bi bi-zoom-out"></i>
        </button>
        <span class="org-chart-zoom-label" data-org-zoom-label>100%</span>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-org-zoom-in title="Acercar">
          <i class="bi bi-zoom-in"></i>
        </button>
        <button type="button" class="btn btn-sm btn-outline-primary" data-org-zoom-fit title="Ajustar">
          <i class="bi bi-arrows-fullscreen me-1"></i>Ajustar
        </button>
        <button type="button" class="btn btn-sm btn-primary" data-org-fullscreen title="Ver en pantalla completa">
          <i class="bi bi-fullscreen me-1" data-org-fullscreen-icon></i>
          <span data-org-fullscreen-label>Pantalla completa</span>
        </button>
      </div>

      <div class="org-chart-wrap" data-org-chart-wrap>
        <div class="org-chart-canvas" data-org-chart-canvas>
          <div class="org-chart" data-org-chart>
            <ul>
              <% for (const r of raices) { %>
                <%- renderNodo(r) %>
              <% } %>
            </ul>
          </div>
        </div>
      </div>

      <script>
      (() => {
        const root = document.currentScript.closest('.card-sicis-body');
        const wrap = root?.querySelector('[data-org-chart-wrap]');
        const canvas = root?.querySelector('[data-org-chart-canvas]');
        const chart = root?.querySelector('[data-org-chart]');
        const label = root?.querySelector('[data-org-zoom-label]');
        const zoomIn = root?.querySelector('[data-org-zoom-in]');
        const zoomOut = root?.querySelector('[data-org-zoom-out]');
        const zoomFit = root?.querySelector('[data-org-zoom-fit]');
        const fullscreenTarget = root?.closest('.card-sicis');
        const fullscreenButton = root?.querySelector('[data-org-fullscreen]');
        const fullscreenIcon = root?.querySelector('[data-org-fullscreen-icon]');
        const fullscreenLabel = root?.querySelector('[data-org-fullscreen-label]');
        if (!wrap || !canvas || !chart) return;

        const minZoom = 0.1;
        const maxZoom = 1.6;
        const step = 0.0125;
        let zoom = 1;

        function clamp(value) {
          return Math.max(minZoom, Math.min(maxZoom, value));
        }

        function measureChart() {
          const rect = chart.getBoundingClientRect();
          const previousTransform = chart.style.transform;
          chart.style.transform = 'scale(1)';
          const width = chart.scrollWidth || rect.width || 1;
          const height = chart.scrollHeight || rect.height || 1;
          chart.style.transform = previousTransform;
          return { width, height };
        }

        function applyZoom(nextZoom, center = true) {
          zoom = clamp(nextZoom);
          const size = measureChart();
          chart.style.transform = `scale(${zoom})`;
          canvas.style.width = `${Math.ceil(size.width * zoom)}px`;
          canvas.style.height = `${Math.ceil(size.height * zoom)}px`;
          if (label) label.textContent = `${Math.round(zoom * 100)}%`;

          if (center) {
            wrap.scrollLeft = 0;
            wrap.scrollTop = 0;
          }
        }

        function fitChart() {
          const size = measureChart();
          const horizontal = (wrap.clientWidth - 24) / Math.max(size.width, 1);
          const vertical = (Math.max(window.innerHeight - wrap.getBoundingClientRect().top - 32, 260)) / Math.max(size.height, 1);
          applyZoom(Math.min(1, horizontal, vertical), true);
        }

        function fullscreenElement() {
          return document.fullscreenElement || document.webkitFullscreenElement || document.msFullscreenElement;
        }

        function isFullscreen() {
          return fullscreenElement() === fullscreenTarget || fullscreenTarget?.classList.contains('org-chart-fullscreen-fallback');
        }

        function syncFullscreenState() {
          const active = isFullscreen();
          fullscreenTarget?.classList.toggle('org-chart-fullscreen', active);
          fullscreenButton?.classList.toggle('btn-primary', !active);
          fullscreenButton?.classList.toggle('btn-outline-primary', active);
          fullscreenButton?.setAttribute('title', active ? 'Salir de pantalla completa' : 'Ver en pantalla completa');
          fullscreenButton?.setAttribute('aria-pressed', String(active));
          if (fullscreenIcon) fullscreenIcon.className = `bi ${active ? 'bi-fullscreen-exit' : 'bi-fullscreen'} me-1`;
          if (fullscreenLabel) fullscreenLabel.textContent = active ? 'Salir' : 'Pantalla completa';
          requestAnimationFrame(fitChart);
        }

        async function enterFullscreen() {
          if (!fullscreenTarget) return;
          try {
            if (fullscreenTarget.requestFullscreen) await fullscreenTarget.requestFullscreen();
            else if (fullscreenTarget.webkitRequestFullscreen) fullscreenTarget.webkitRequestFullscreen();
            else if (fullscreenTarget.msRequestFullscreen) fullscreenTarget.msRequestFullscreen();
            else fullscreenTarget.classList.add('org-chart-fullscreen-fallback');
          } catch (err) {
            fullscreenTarget.classList.add('org-chart-fullscreen-fallback');
          }
          syncFullscreenState();
        }

        async function exitFullscreen() {
          fullscreenTarget?.classList.remove('org-chart-fullscreen-fallback');
          try {
            if (document.exitFullscreen && fullscreenElement()) await document.exitFullscreen();
            else if (document.webkitExitFullscreen && fullscreenElement()) document.webkitExitFullscreen();
            else if (document.msExitFullscreen && fullscreenElement()) document.msExitFullscreen();
          } catch (err) {
            fullscreenTarget?.classList.remove('org-chart-fullscreen');
          }
          syncFullscreenState();
        }

        zoomIn?.addEventListener('click', () => applyZoom(zoom + step, false));
        zoomOut?.addEventListener('click', () => applyZoom(zoom - step, false));
        zoomFit?.addEventListener('click', fitChart);
        fullscreenButton?.addEventListener('click', () => {
          if (isFullscreen()) exitFullscreen();
          else enterFullscreen();
        });
        wrap.addEventListener('wheel', (event) => {
          if (!event.ctrlKey) return;
          event.preventDefault();
          const direction = event.deltaY < 0 ? 1 : -1;
          applyZoom(zoom + (direction * step), false);
        }, { passive: false });
        window.addEventListener('resize', fitChart, { passive: true });
        document.addEventListener('fullscreenchange', syncFullscreenState);
        document.addEventListener('webkitfullscreenchange', syncFullscreenState);
        document.addEventListener('msfullscreenchange', syncFullscreenState);

        requestAnimationFrame(fitChart);
      })();
      </script>
    <% } %>
  </div>
</div>
