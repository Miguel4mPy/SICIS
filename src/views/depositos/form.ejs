<% if (errors && errors.length) { %>
<div class="alert alert-danger"><%= errors[0] %></div>
<% } %>
<div class="row justify-content-center">
<div class="col-xl-8">
<div class="card-sicis">
  <div class="card-sicis-header"><i class="bi bi-building me-2"></i><%= deposito.id ? 'Editar' : 'Nuevo' %> Depósito</div>
  <div class="card-sicis-body">
    <form method="POST" action="/depositos<%= deposito.id ? '/' + deposito.id : '' %>">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label required">Código</label>
          <input type="text" name="codigo" class="form-control" value="<%= deposito.codigo || '' %>" required placeholder="DEP-ZN-020" <%= deposito.id ? 'readonly' : '' %>>
        </div>
        <div class="col-md-8">
          <label class="form-label required">Nombre</label>
          <input type="text" name="nombre" class="form-control" value="<%= deposito.nombre || '' %>" required>
        </div>
        <div class="col-md-4">
          <label class="form-label required">Tipo</label>
          <select name="tipo" class="form-select" required>
            <option value="oficina_central" <%= deposito.tipo === 'oficina_central' ? 'selected' : '' %>>Oficina Central</option>
            <option value="zona" <%= deposito.tipo === 'zona' ? 'selected' : '' %>>Deposito Zona</option>
            <option value="sector" <%= deposito.tipo === 'sector' ? 'selected' : '' %>>Deposito Sector</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label required">Nivel</label>
          <select name="nivel" class="form-select" required>
            <option value="1" <%= deposito.nivel == 1 ? 'selected' : '' %>>Nivel 1 - Central</option>
            <option value="2" <%= deposito.nivel == 2 ? 'selected' : '' %>>Nivel 2 - Zona</option>
            <option value="3" <%= deposito.nivel == 3 ? 'selected' : '' %>>Nivel 3 - Sector</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Depósito Padre</label>
          <select name="deposito_padre_id" class="form-select">
            <option value="">Sin padre (raíz)</option>
            <% for (const p of padres) { %>
            <option value="<%= p.id %>" <%= deposito.deposito_padre_id == p.id ? 'selected' : '' %>>N<%= p.nivel %> — <%= p.nombre %></option>
            <% } %>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">Departamento</label>
          <input type="text" name="departamento" class="form-control" value="<%= deposito.departamento || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label">Zona</label>
          <input type="text" name="zona" class="form-control" value="<%= deposito.zona || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label">Responsable</label>
          <input type="text" name="responsable_nombre" class="form-control" value="<%= deposito.responsable_nombre || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label">Dirección</label>
          <input type="text" name="direccion" class="form-control" value="<%= deposito.direccion || '' %>">
        </div>
        <% if (deposito.id) { %>
        <div class="col-12">
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" name="activo" id="activo" <%= deposito.activo ? 'checked' : '' %>>
            <label class="form-check-label" for="activo">Depósito activo</label>
          </div>
        </div>
        <% } %>
      </div>
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Guardar</button>
        <a href="/depositos" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
</div>
</div>
